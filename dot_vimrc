set nocompatible
let mapleader = " "
syntax on
filetype plugin indent on

set number
set relativenumber

set ignorecase
set smartcase
set incsearch
set hlsearch

set tabstop=4
set shiftwidth=4
set expandtab

set autoindent
set backspace=indent,eol,start

set wildmenu
set laststatus=2
set ruler
set showcmd
set scrolloff=8

nnoremap <leader>h :nohlsearch<CR>
