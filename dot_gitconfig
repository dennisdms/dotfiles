[include]
	path = ~/.gitconfig.local

[core]
	pager = delta
	editor = vim

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	side-by-side = true

[pager]
	diff = delta

[help]
	autocorrect = immediate

[push]
	autoSetupRemote = true

[alias]
	s = status -s
	cam = commit -am
